function renderGroups() {
  groupsCount.textContent = `Mostrando ${groupsCache.length} grupos.`;

  if (!groupsCache.length) {
    groupsBody.innerHTML = `<tr><td class="muted" colspan="2">Sin grupos</td></tr>`;
    return;
  }

  groupsBody.innerHTML = groupsCache.map(groupName => `
    <tr>
      <td>${escapeHtml(groupName)}</td>
      <td><button class="danger deleteGroupBtn" data-group="${escapeHtml(groupName)}">Eliminar</button></td>
    </tr>
  `).join("");

  groupsBody.querySelectorAll(".deleteGroupBtn").forEach(btn => {
    btn.addEventListener("click", async () => {
      const groupName = btn.getAttribute("data-group");
      const ok = window.confirm(`¿Eliminar el grupo "${groupName}"?\nLas personas quedarán sin grupo.`);
      if (!ok) return;

      try {
        await api("/api/groups/delete", {
          method: "POST",
          body: JSON.stringify({ groupName })
        });
        setMessage(`Grupo eliminado: ${groupName}`, "ok");
        await refreshAll();
      } catch (e) {
        setMessage(e.message, "bad");
      }
    });
  });
}

