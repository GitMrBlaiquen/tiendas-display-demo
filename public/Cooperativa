app.get("/api/export/excel", async (req, res) => {
  const db = await loadDb();

  const rows = [];
  const assignmentsByRut = new Map();

  for (const a of Object.values(db.assignments)) {
    const list = assignmentsByRut.get(a.person_rut) || [];
    list.push(a.radio_code);
    assignmentsByRut.set(a.person_rut, list);
  }

  for (const person of Object.values(db.people).sort((a, b) => a.name.localeCompare(b.name))) {
    const radios = assignmentsByRut.get(person.rut) || [];
    if (!radios.length) {
      rows.push({
        Nombre: person.name,
        RUT: person.rut,
        Grupo: person.groupName || "",
        "Radio asignada": ""
      });
    } else {
      for (const radio of radios) {
        rows.push({
          Nombre: person.name,
          RUT: person.rut,
          Grupo: person.groupName || "",
          "Radio asignada": radio
        });
      }
    }
  }

  const wb = XLSX.utils.book_new();
  const ws = XLSX.utils.json_to_sheet(rows);
  XLSX.utils.book_append_sheet(wb, ws, "Radios");

  const buf = XLSX.write(wb, { type: "buffer", bookType: "xlsx" });
  const filename = `radios_export_${new Date().toISOString().slice(0, 10)}.xlsx`;

  res.setHeader("Content-Type", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
  res.setHeader("Content-Disposition", `attachment; filename="${filename}"`);
  res.send(buf);
});

