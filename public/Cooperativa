// ---------- Cámara carnet (ZXing, mejor para iPhone/Android) ----------
function openQrModal() {
  qrMsg.textContent = "";
  qrModal.classList.remove("hidden");
}

function closeQrModal() {
  stopQrCamera();
  qrModal.classList.add("hidden");
}

async function startQrCamera() {
  qrMsg.textContent = "";

  if (!window.ZXing) {
    qrMsg.textContent = "No se cargó la librería de escaneo.";
    return;
  }

  if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
    qrMsg.textContent = "Este navegador no soporta acceso a cámara.";
    return;
  }

  try {
    stopQrCamera();

    qrCodeReader = new ZXing.BrowserMultiFormatReader();
    qrStreamActive = true;

    qrMsg.textContent = "Solicitando cámara...";

    await qrCodeReader.decodeFromConstraints(
      {
        audio: false,
        video: {
          facingMode: { ideal: "environment" },
          width: { ideal: 1280 },
          height: { ideal: 720 }
        }
      },
      qrVideo,
      async (result, err) => {
        if (!qrStreamActive) return;

        if (result) {
          const raw = result.getText ? result.getText() : String(result.text || "");
          qrMsg.textContent = `Leído: ${raw}`;

          const rut = extractRutFromScan(raw);
          if (rut) {
            try {
              await selectPersonByRut(rut);
              setMessage(`Carnet leído por cámara: ${rut}`, "ok");
              closeQrModal();
            } catch (e) {
              setMessage(e.message, "bad");
            }
          }
        }
      }
    );

    qrMsg.textContent = "Cámara activa. Apunta al carnet...";
  } catch (e) {
    console.error("ZXing camera error:", e);
    qrMsg.textContent = `No se pudo iniciar la cámara: ${e?.message || e}`;
  }
}

function stopQrCamera() {
  qrStreamActive = false;

  try {
    if (qrCodeReader?.reset) qrCodeReader.reset();
  } catch {}

  if (qrVideo) {
    try { qrVideo.pause(); } catch {}
    qrVideo.srcObject = null;
  }

  qrMsg.textContent = "Cámara detenida.";
}

btnScanQr?.addEventListener("click", openQrModal);
btnQrClose?.addEventListener("click", closeQrModal);
btnQrStart?.addEventListener("click", startQrCamera);
btnQrStop?.addEventListener("click", stopQrCamera);