display.addEventListener("click", (e) => {
  e.preventDefault();
  e.stopPropagation();

  const willOpen = optionsBox.style.display !== "block";

  // cerrar otros selects
  closeAllCustomSelects();

  if (!willOpen) {
    optionsBox.classList.remove("is-open");
    optionsBox.style.display = "none";
    wrapper.classList.remove("is-open");
    return;
  }

  // Montar en body si aún no está
  if (!optionsMounted) {
    document.body.appendChild(optionsBox);
    optionsMounted = true;
  }

  // Posicionar debajo del botón
  const r = display.getBoundingClientRect();
  optionsBox.style.left = `${r.left}px`;
  optionsBox.style.top  = `${r.bottom + 8}px`;
  optionsBox.style.width = `${r.width}px`;

  optionsBox.style.display = "block";

  requestAnimationFrame(() => {
    optionsBox.classList.add("is-open");
  });

  wrapper.classList.add("is-open");
});