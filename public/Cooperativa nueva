  const storeName = getStoreName(currentStoreId);
  const ok = confirm(
    `⚠️ Vas a RESETEAR a 0 la tienda:\n\n${storeName} (${currentStoreId})\n\n¿Continuar?`
  );
  if (!ok) return;

  try {
