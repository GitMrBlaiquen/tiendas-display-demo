const SIM_STORAGE_KEY = "smartcountify_store_simulation";

function getSimulationConfig() {
  try {
    const raw = localStorage.getItem(SIM_STORAGE_KEY);
    if (!raw) {
      return { enabled: false, storeId: "arrow-01" };
    }

    const parsed = JSON.parse(raw);
    return {
      enabled: !!parsed?.enabled,
      storeId: parsed?.storeId ? String(parsed.storeId) : "arrow-01",
    };
  } catch {
    return { enabled: false, storeId: "arrow-01" };
  }
}

function setSimulationConfig(storeId, enabled) {
  const cfg = {
    enabled: !!enabled,
    storeId: storeId ? String(storeId) : "arrow-01",
  };
  localStorage.setItem(SIM_STORAGE_KEY, JSON.stringify(cfg));
  return cfg;
}

function isSimulationActiveForStore(storeId) {
  const cfg = getSimulationConfig();
  return !!cfg.enabled && !!cfg.storeId && String(cfg.storeId) === String(storeId || "");
}

function getSimSeed(storeId) {
  const str = String(storeId || "default");
  let h = 0;
  for (let i = 0; i < str.length; i++) {
    h = (h * 31 + str.charCodeAt(i)) >>> 0;
  }
  return h || 12345;
}

function makeSimRng(seed) {
  let s = seed >>> 0;
  return function rand() {
    s = (1664525 * s + 1013904223) >>> 0;
    return s / 4294967296;
  };
}

function getSimulatedCounters(storeId) {
  const now = new Date();
  const minutes = now.getHours() * 60 + now.getMinutes();
  const daySeed = getSimSeed(storeId) + now.getDate() + now.getMonth() * 31;
  const rand = makeSimRng(daySeed);

  const openStart = 10 * 60;
  const openEnd = 22 * 60;
  const isOpenHours = minutes >= openStart && minutes <= openEnd;

  let phase = 0;
  if (isOpenHours) {
    phase = (minutes - openStart) / Math.max(openEnd - openStart, 1);
  }

  const waveA = Math.sin(phase * Math.PI);
  const waveB = Math.sin(phase * Math.PI * 2);
  const activity = isOpenHours ? Math.max(0, waveA * 0.95 + waveB * 0.15) : 0;

  const entradas = Math.max(0, Math.round(activity * 42 + rand() * 6));
  const salidas = Math.max(0, Math.round(activity * 30 + rand() * 5));
  const inChild = Math.max(0, Math.round(activity * 8 + rand() * 2));
  const outChild = Math.max(0, Math.round(activity * 6 + rand() * 2));
  const workersIn = isOpenHours ? 2 + Math.floor(rand() * 4) : 0;

  const totalEntradas = entradas + inChild + workersIn;
  const totalSalidas = salidas + outChild;
  const dentro = Math.max(0, entradas - salidas + Math.floor(rand() * 5));

  return {
    storeId,
    entradas,
    salidas,
    dentro,
    inChild,
    outChild,
    workersIn,
    totalEntradas,
    totalSalidas,
    simulated: true,
  };
}

function getSimulatedStatus(storeId) {
  const now = new Date();
  const isOpenHours = now.getHours() >= 10 && now.getHours() <= 22;

  return {
    storeId,
    online: isOpenHours,
    sn: `SIM-${String(storeId || "STORE").toUpperCase()}`,
    simulated: true,
  };
}

function buildSimulatedHistory(storeId, isoDate) {
  const seedBase = getSimSeed(storeId) + Number(String(isoDate || "").replaceAll("-", "") || 0);
  const rand = makeSimRng(seedBase);

  const entradas = 140 + Math.floor(rand() * 90);
  const salidas = 110 + Math.floor(rand() * 80);
  const inChild = 12 + Math.floor(rand() * 12);
  const outChild = 10 + Math.floor(rand() * 10);
  const workersIn = 3 + Math.floor(rand() * 4);

  const byHour = {};
  let remainingE = entradas;
  let remainingS = salidas;

  for (let h = 0; h < 24; h++) {
    const hh = String(h).padStart(2, "0");

    let e = 0;
    let s = 0;

    if (h >= 10 && h <= 21) {
      const bias = Math.sin(((h - 10) / 11) * Math.PI);
      e = Math.max(0, Math.round(bias * 18 + rand() * 4));
      s = Math.max(0, Math.round(bias * 14 + rand() * 4));
    }

    byHour[hh] = {
      entradas: e,
      salidas: s,
    };
  }

  const hours = Object.keys(byHour);
  let sumE = hours.reduce((a, h) => a + byHour[h].entradas, 0);
  let sumS = hours.reduce((a, h) => a + byHour[h].salidas, 0);

  if (sumE === 0) sumE = 1;
  if (sumS === 0) sumS = 1;

  hours.forEach((h, idx) => {
    byHour[h].entradas = Math.round((byHour[h].entradas / sumE) * entradas);
    byHour[h].salidas = Math.round((byHour[h].salidas / sumS) * salidas);

    remainingE -= byHour[h].entradas;
    remainingS -= byHour[h].salidas;

    if (idx === hours.length - 1) {
      byHour[h].entradas += remainingE;
      byHour[h].salidas += remainingS;
    }
  });

  return {
    storeId,
    date: isoDate,
    entradas,
    salidas,
    inChild,
    outChild,
    workersIn,
    byHour,
    simulated: true,
  };
}

