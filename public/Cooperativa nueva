let __customSelectDocCloserReady = false;

function closeAllCustomSelects() {
  document.querySelectorAll(".custom-select.is-open").forEach((w) => w.classList.remove("is-open"));
  document.querySelectorAll(".custom-select-portal").forEach((box) => {
    box.classList.remove("is-open");
    box.style.display = "none";
  });
}

function removeCustomSelect(selectId) {
  const original = document.getElementById(selectId);
  if (!original) return;

  const next = original.nextElementSibling;
  if (next && next.classList && next.classList.contains("custom-select")) {
    next.remove();
  }

  const portalId = original.dataset.portalId;
  if (portalId) {
    const portal = document.getElementById(portalId);
    if (portal) portal.remove();
    delete original.dataset.portalId;
  }

  original.style.display = "";
  original.classList.remove("native-select-hidden");
  delete original.dataset.customReady;
}

function makeCustomSelect(selectId, { iconSrc = "" } = {}) {
  const original = document.getElementById(selectId);
  if (!original) return;

  if (original.dataset.customReady === "1") return;
  original.dataset.customReady = "1";

  if (!__customSelectDocCloserReady) {
    __customSelectDocCloserReady = true;
    document.addEventListener("click", () => closeAllCustomSelects());
    window.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeAllCustomSelects();
    });
  }

  original.classList.add("native-select-hidden");
  original.style.display = "none";

  const wrapper = document.createElement("div");
  wrapper.className = "custom-select";

  const display = document.createElement("button");
  display.type = "button";
  display.className = "custom-select-display";

  if (iconSrc) {
    const ico = document.createElement("img");
    ico.src = iconSrc;
    ico.alt = "";
    ico.className = "custom-select-icon";
    display.appendChild(ico);
  }

  const txt = document.createElement("span");
  txt.className = "custom-select-text";
  txt.textContent = original.options[original.selectedIndex]?.text || "Seleccionar";
  display.appendChild(txt);

  const arrow = document.createElement("span");
  arrow.className = "custom-select-arrow";
  arrow.textContent = "▾";
  display.appendChild(arrow);

  const portalId = `cs-portal-${selectId}`;
  original.dataset.portalId = portalId;

  const optionsBox = document.createElement("div");
  optionsBox.id = portalId;
  optionsBox.className = "custom-select-portal";
  optionsBox.style.display = "none";

  optionsBox.style.position = "fixed";
  optionsBox.style.zIndex = "999999";
  optionsBox.style.maxHeight = "280px";
  optionsBox.style.overflow = "auto";
  optionsBox.style.borderRadius = "12px";
  optionsBox.style.boxShadow = "0 16px 40px rgba(0,0,0,.18)";
  optionsBox.style.background = "rgba(255,255,255,.98)";
  optionsBox.style.border = "1px solid rgba(0,0,0,.08)";
  optionsBox.style.padding = "6px";

  let optionsMounted = false;

  function syncText() {
    txt.textContent = original.options[original.selectedIndex]?.text || "Seleccionar";
  }

  function rebuildOptions() {
    optionsBox.innerHTML = "";

    Array.from(original.options).forEach((opt) => {
      const item = document.createElement("button");
      item.type = "button";
      item.className = "custom-select-option";
      item.textContent = opt.text;

      item.style.display = "block";
      item.style.width = "100%";
      item.style.textAlign = "left";
      item.style.padding = "10px 12px";
      item.style.border = "0";
      item.style.background = "transparent";
      item.style.borderRadius = "10px";
      item.style.cursor = "pointer";
      item.style.color = "#0A2342";
      item.style.fontWeight = "700";

      item.addEventListener("mouseenter", () => {
        item.style.background = "rgba(10,35,66,.08)";
      });
      item.addEventListener("mouseleave", () => {
        item.style.background = "transparent";
      });

      item.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();

        original.value = opt.value;
        syncText();

        closeAllCustomSelects();
        original.dispatchEvent(new Event("change", { bubbles: true }));
      });

      optionsBox.appendChild(item);
    });

    syncText();
  }

  function repositionIfOpen() {
    if (optionsBox.style.display !== "block") return;

    const r = display.getBoundingClientRect();
    const gap = 8;

    optionsBox.style.left = `${Math.round(r.left)}px`;
    optionsBox.style.top = `${Math.round(r.bottom + gap)}px`;
    optionsBox.style.width = `${Math.round(r.width)}px`;
  }

  window.addEventListener("scroll", repositionIfOpen, true);
  window.addEventListener("resize", repositionIfOpen);

  display.addEventListener("click", (e) => {
    e.preventDefault();
    e.stopPropagation();

    const willOpen = optionsBox.style.display !== "block";

    closeAllCustomSelects();

    if (!willOpen) return;

    if (!optionsMounted) {
      document.body.appendChild(optionsBox);
      optionsMounted = true;
    }

    rebuildOptions();

    optionsBox.style.visibility = "hidden";
    optionsBox.style.display = "block";

    const r = display.getBoundingClientRect();
    const gap = 8;

    optionsBox.style.left = `${Math.round(r.left)}px`;
    optionsBox.style.top = `${Math.round(r.bottom + gap)}px`;
    optionsBox.style.width = `${Math.round(r.width)}px`;

    optionsBox.style.visibility = "visible";

    wrapper.classList.add("is-open");
    optionsBox.classList.add("is-open");
  });

  wrapper.appendChild(display);
  original.parentNode.insertBefore(wrapper, original.nextSibling);

  const obs = new MutationObserver(() => {
    rebuildOptions();
    syncText();
    repositionIfOpen();
  });
  obs.observe(original, { childList: true });

  rebuildOptions();
  syncText();
}

