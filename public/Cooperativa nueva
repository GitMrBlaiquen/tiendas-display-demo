      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ storeId: currentStoreId }),
    });

    if (!res.ok) {
      let msg = "";
      try {
        const j = await res.json();
        msg = j?.error || j?.msg || "";
      } catch {
        msg = await res.text().catch(() => "");
      }
      throw new Error(msg || `Error ${res.status}`);
