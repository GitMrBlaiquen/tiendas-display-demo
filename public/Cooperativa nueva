function buildClientListForTerminal(stores) {
  const list = buildClientsFromStores(stores || []);
  list.sort((a, b) => a.name.localeCompare(b.name, "es"));
  return list;
}

function fillTerminalClientSelect() {
  if (!terminalClientFilter) return;

  const list = buildClientListForTerminal(currentStores);

  terminalClientFilter.innerHTML = "";

  const optAll = document.createElement("option");
  optAll.value = "all";
  optAll.textContent = "Todos";
  terminalClientFilter.appendChild(optAll);

  list.forEach((c) => {
    const opt = document.createElement("option");
    opt.value = c.id;
    opt.textContent = c.name;
    terminalClientFilter.appendChild(opt);
  });

  const prev = terminalClientFilter.dataset.selected || "all";
  terminalClientFilter.value = prev;
}

function getTerminalFilters() {
  const clientId = terminalClientFilter?.value || "all";
  const status = statusFilter?.value || "all";
  const q = (terminalSearch?.value || "").trim().toLowerCase();
  return { clientId, status, q };
}

function applyTerminalFiltersAndRender() {
  const { clientId, status, q } = getTerminalFilters();

  let list = Array.isArray(lastAllStatusesCache) ? [...lastAllStatusesCache] : [];

  if (clientId !== "all") {
    list = list.filter((x) => getClientIdFromStoreId(x.storeId) === clientId);
  }

  if (status === "online") list = list.filter((x) => x.online === true);
  if (status === "offline") list = list.filter((x) => x.online === false);

  if (q) {
    list = list.filter((x) => {
      const name = String(x.storeName || getStoreName(x.storeId) || "").toLowerCase();
      const id = String(x.storeId || "").toLowerCase();
      const sn = String(x.sn || "").toLowerCase();
      return name.includes(q) || id.includes(q) || sn.includes(q);
    });
  }

  renderAllStatuses(list, "all");
}

